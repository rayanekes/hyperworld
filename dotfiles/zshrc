# ══════════════════════════════════════════════════════════
#  FONCTIONS UTILES
# ══════════════════════════════════════════════════════════

# Créer un dossier et y entrer
mkcd() { mkdir -p "$1" && cd "$1"; }

# Extraire n'importe quelle archive
extract() {
    case "$1" in
        *.tar.gz|*.tgz)   tar -xzvf "$1" ;;
        *.tar.bz2|*.tbz2) tar -xjvf "$1" ;;
        *.tar.xz)          tar -xJvf "$1" ;;
        *.zip)             unzip "$1" ;;
        *.7z)              7z x "$1" ;;
        *.rar)             unrar x "$1" ;;
        *.gz)              gunzip "$1" ;;
        *)                 echo "Format non supporté : $1" ;;
    esac
}

# Chercher dans l'historique avec fzf
fh() {
    print -z "$(fc -ln 1 | fzf --tac --no-sort | sed 's/ *[0-9]* *//')"
}

# Voir les ports ouverts joliment
listening() {
    ss -tulnp | grep LISTEN | awk '{print $1, $5}' | column -t
}

# Status rapide HYPERWORLD
hw-status() {
    echo -e "\n\033[96m  ═══ HYPERWORLD STATUS ═══\033[0m"
    echo -e "  GPU  : $(nvidia-smi --query-gpu=temperature.gpu,utilization.gpu --format=csv,noheader 2>/dev/null || echo '?')"
    echo -e "  RAM  : $(free -h | awk '/^Mem/{print $3"/"$2}')"
    echo -e "  AXIOM: $(systemctl --user is-active axiom.service 2>/dev/null || echo 'inactif')"
    echo -e "  Monde: $(hyprctl activeworkspace -j 2>/dev/null | python3 -c "import sys,json; ws=json.load(sys.stdin)['id']; print('🎮 Gaming' if ws<=3 else '🛡️ Cybersec' if ws<=6 else '🔬 Prog')" 2>/dev/null || echo '?')"
    echo ""
}

